# Copy to .env and fill in real values. NEVER commit .env.
# These same DB_* vars are read by docker-compose.yml AND by the Athena app.

# --- LLM (required) ---
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_MAX_TOKENS=4096

# --- Observability (optional in Phase 1) ---
# Get a free key at https://smith.langchain.com
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=athena-dev
# LANGSMITH_TRACING=true

# --- Database ---
# docker-compose uses these for the container; the app builds DATABASE_URL from them.
DB_USER=lkallam
DB_PASSWORD=password
DB_NAME=my_database
DB_HOST=localhost
DB_PORT=5432

# Connection pool tuning (sane defaults; usually no need to change)
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- pgAdmin (for docker-compose only) ---
PGADMIN_EMAIL=kallamlaksh@gmail.com
PGADMIN_PASSWORD=password

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- RAG knobs (Phase 1.3+) ---
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_PCT=0.15
RETRIEVER_TOP_K=50
RERANKER_TOP_N=5
